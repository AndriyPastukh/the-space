generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  passwordHash  String
  refreshTokens RefreshToken[]
  profile       Profile?
}

model Profile {
  id             Int             @id @default(autoincrement())
  userId         Int             @unique
  user           User            @relation(fields: [userId], references: [id])
  firstName      String?
  lastName       String?
  nickname       String          @unique
  bio            String?
  avatarUrl      String          @default("https://api.dicebear.com/7.x/avataaars/svg?seed=default")
  skillTags      String[]
  interestTags   String[]
  totalXP        Int             @default(0)
  reviews        Review[]        @relation("UserReviews")
  givenReviews   Review[]        @relation("GivenReviews")
  badges         UserBadge[]
  communities    UserCommunity[]
  portfolioItems PortfolioItem[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  profileId Int
  profile   Profile  @relation("UserReviews", fields: [profileId], references: [id])
  authorId  Int
  author    Profile  @relation("GivenReviews", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model Badge {
  id          Int         @id @default(autoincrement())
  name        String
  iconUrl     String
  description String?
  users       UserBadge[]
}

model UserBadge {
  profileId Int
  profile   Profile  @relation(fields: [profileId], references: [id])
  badgeId   Int
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now())

  @@id([profileId, badgeId])
}

model Community {
  id        Int             @id @default(autoincrement())
  name      String
  slug      String          @unique
  avatarUrl String?
  users     UserCommunity[]
}

model UserCommunity {
  profileId   Int
  profile     Profile   @relation(fields: [profileId], references: [id])
  communityId Int
  community   Community @relation(fields: [communityId], references: [id])
  joinedAt    DateTime  @default(now())

  @@id([profileId, communityId])
}

model PortfolioItem {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  link        String?
  profileId   Int
  profile     Profile  @relation(fields: [profileId], references: [id])
  createdAt   DateTime @default(now())
}
