generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  passwordHash  String
  refreshTokens RefreshToken[]
  userDetails   UserDetails?
  knowledges    Knowledge[]
  tasks         Task[]
  communities   Community[]
  teams         Team[]
}

enum UserStatus {
  STUDENT
  FREELANCER
  EMPLOYED
  ENTREPRENEUR
}

model UserDetails {
  id             Int             @id @default(autoincrement())
  userId         Int             @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName      String
  middleName     String?
  lastName       String
  nickname       String          @unique
  phoneNumber    String?         @unique
  bio            String?         @db.Text
  avatarUrl      String          @default("https://api.dicebear.com/7.x/avataaars/svg?seed=default")
  coverImageUrl  String?
  xpPoints       Int             @default(0)
  currentLevel   Int             @default(1)
  reputation     Float           @default(0.0)
  status         UserStatus      @default(STUDENT)
  birthday       DateTime?
  country        String?
  city           String?
  deletedAt      DateTime?
  
  categories     Category[]
  socialLinks    SocialLink[]
  skills         Tag[]           @relation("ProfileSkills")
  interests      Tag[]           @relation("ProfileInterests")
  reviews        Review[]        @relation("UserReviews")
  givenReviews   Review[]        @relation("GivenReviews")
  badges         UserBadge[]
  communities    UserCommunity[]
  teams          UserTeam[]
  communityJoinRequests CommunityJoinRequest[]
  teamJoinRequests      TeamJoinRequest[]
  portfolioItems PortfolioItem[]

  @@index([nickname])
  @@index([phoneNumber])
  @@index([city])
}

model Category {
  id       Int    @id @default(autoincrement())
  name     String @unique

  userDetails       UserDetails[]
  tasks             Task[]
  knowledgeOffers   Knowledge[] @relation("KnowledgeOffers")
  knowledgeRequests Knowledge[] @relation("KnowledgeRequests")
  communities       Community[]
  teams             Team[]
}

model SocialLink {
  id           Int      @id @default(autoincrement())
  platformName String
  url          String
  userDetailsId Int
  userDetails  UserDetails @relation(fields: [userDetailsId], references: [id], onDelete: Cascade)
}

model Tag {
  id               String    @id @default(uuid())
  name             String    @unique
  profilesSkill    UserDetails[] @relation("ProfileSkills")
  profilesInterest UserDetails[] @relation("ProfileInterests")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Review {
  id            Int         @id @default(autoincrement())
  rating        Int
  comment       String?
  userDetailsId Int
  userDetails   UserDetails @relation("UserReviews", fields: [userDetailsId], references: [id])
  authorId      Int
  author        UserDetails @relation("GivenReviews", fields: [authorId], references: [id])
  createdAt     DateTime    @default(now())
}

model Badge {
  id          Int         @id @default(autoincrement())
  name        String
  iconUrl     String
  description String?
  users       UserBadge[]
}

model UserBadge {
  userDetailsId Int
  userDetails   UserDetails @relation(fields: [userDetailsId], references: [id])
  badgeId       Int
  badge         Badge       @relation(fields: [badgeId], references: [id])
  earnedAt      DateTime    @default(now())

  @@id([userDetailsId, badgeId])
}

enum SpaceMemberRole {
  OWNER
  MODERATOR
  CONTRIBUTOR
  MEMBER
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Community {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  avatarUrl    String?
  authorId     Int
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  directions   Category[]
  users        UserCommunity[]
  joinRequests CommunityJoinRequest[]
  viewsCount   Int      @default(0)
  postsCount   Int      @default(0)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([authorId])
  @@index([slug])
  @@index([deletedAt])
  @@index([createdAt])
}

model Team {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  avatarUrl    String?
  authorId     Int
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  directions   Category[]
  users        UserTeam[]
  joinRequests TeamJoinRequest[]
  viewsCount   Int      @default(0)
  postsCount   Int      @default(0)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([authorId])
  @@index([slug])
  @@index([deletedAt])
  @@index([createdAt])
}

model UserCommunity {
  userDetailsId Int
  userDetails   UserDetails @relation(fields: [userDetailsId], references: [id], onDelete: Cascade)
  communityId   Int
  community     Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)
  role          SpaceMemberRole @default(MEMBER)
  joinedAt      DateTime @default(now())

  @@id([userDetailsId, communityId])
}

model UserTeam {
  userDetailsId Int
  userDetails   UserDetails @relation(fields: [userDetailsId], references: [id], onDelete: Cascade)
  teamId        Int
  team          Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role          SpaceMemberRole @default(MEMBER)
  joinedAt      DateTime @default(now())

  @@id([userDetailsId, teamId])
}

model CommunityJoinRequest {
  id            Int               @id @default(autoincrement())
  communityId   Int
  community     Community         @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userDetailsId Int
  userDetails   UserDetails       @relation(fields: [userDetailsId], references: [id], onDelete: Cascade)
  status        JoinRequestStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([communityId, userDetailsId])
  @@index([status])
}

model TeamJoinRequest {
  id            Int               @id @default(autoincrement())
  teamId        Int
  team          Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userDetailsId Int
  userDetails   UserDetails       @relation(fields: [userDetailsId], references: [id], onDelete: Cascade)
  status        JoinRequestStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([teamId, userDetailsId])
  @@index([status])
}

model PortfolioItem {
  id            Int         @id @default(autoincrement())
  title         String
  description   String?
  link          String?
  userDetailsId Int
  userDetails   UserDetails @relation(fields: [userDetailsId], references: [id])
  createdAt     DateTime    @default(now())
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

model Task {
  id        String   @id @default(uuid())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  points      Int        @default(0)
  status      TaskStatus @default(OPEN)

  deadline    DateTime?
  urls        String[]   @default([])
  files       String[]   @default([])

  authorId    Int
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categories Category[]

  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

model Knowledge {
  id                 String     @id @default(uuid())
  offerDescription   String     @db.VarChar(2000)
  requestDescription String     @db.VarChar(2000)
  deadline           DateTime
  urls               String[]
  authorId           Int
  author             User       @relation(fields: [authorId], references: [id])
  deletedAt          DateTime?

  offerCategories    Category[] @relation("KnowledgeOffers")
  requestCategories  Category[] @relation("KnowledgeRequests")

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

view UserStats {
  userDetailsId Int   @unique
  averageRating Float
  reviewCount   Int
}

