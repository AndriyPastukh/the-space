generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  passwordHash  String
  refreshTokens RefreshToken[]
  profile       Profile?
  knowledges    Knowledge[]
}

enum UserStatus {
  STUDENT
  FREELANCER
  EMPLOYED
  ENTREPRENEUR
}

model Profile {
  id             Int             @id @default(autoincrement())
  userId         Int             @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName      String          @default("New")
  lastName       String          @default("User")
  nickname       String          @unique
  phoneNumber    String?         @unique
  bio            String?         @db.Text
  avatarUrl      String          @default("https://api.dicebear.com/7.x/avataaars/svg?seed=default")
  coverImageUrl  String?
  xpPoints       Int             @default(0)
  currentLevel   Int             @default(1)
  reputation     Float           @default(0.0)
  status         UserStatus      @default(STUDENT)
  birthday       DateTime?
  country        String?
  city           String?
  deletedAt      DateTime?
  
  socialLinks    SocialLink[]
  skills         Tag[]           @relation("ProfileSkills")
  interests      Tag[]           @relation("ProfileInterests")
  reviews        Review[]        @relation("UserReviews")
  givenReviews   Review[]        @relation("GivenReviews")
  badges         UserBadge[]
  communities    UserCommunity[]
  portfolioItems PortfolioItem[]
  tasks          Task[]

  @@index([nickname])
  @@index([phoneNumber])
  @@index([city])
}

model SocialLink {
  id           Int      @id @default(autoincrement())
  platformName String
  url          String
  profileId    Int
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Tag {
  id               String    @id @default(uuid())
  name             String    @unique
  profilesSkill    Profile[] @relation("ProfileSkills")
  profilesInterest Profile[] @relation("ProfileInterests")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  profileId Int
  profile   Profile  @relation("UserReviews", fields: [profileId], references: [id])
  authorId  Int
  author    Profile  @relation("GivenReviews", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model Badge {
  id          Int         @id @default(autoincrement())
  name        String
  iconUrl     String
  description String?
  users       UserBadge[]
}

model UserBadge {
  profileId Int
  profile   Profile  @relation(fields: [profileId], references: [id])
  badgeId   Int
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now())

  @@id([profileId, badgeId])
}

model Community {
  id        Int             @id @default(autoincrement())
  name      String
  slug      String          @unique
  avatarUrl String?
  users     UserCommunity[]
}

model UserCommunity {
  profileId   Int
  profile     Profile   @relation(fields: [profileId], references: [id])
  communityId Int
  community   Community @relation(fields: [communityId], references: [id])
  joinedAt    DateTime  @default(now())

  @@id([profileId, communityId])
}

model PortfolioItem {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  link        String?
  profileId   Int
  profile     Profile  @relation(fields: [profileId], references: [id])
  createdAt   DateTime @default(now())
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  points      Int      @default(0)
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  profileId   Int?
  profile     Profile? @relation(fields: [profileId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Knowledge {
  id                 String     @id @default(uuid())
  offerDescription   String     @db.VarChar(2000)
  requestDescription String     @db.VarChar(2000)
  deadline           DateTime
  urls               String[]
  authorId           Int
  author             User       @relation(fields: [authorId], references: [id])
  deletedAt          DateTime?

  offerCategories    Category[] @relation("KnowledgeOffers")
  requestCategories  Category[] @relation("KnowledgeRequests")

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Category {
  id                String      @id @default(uuid())
  name              String      @unique
  knowledgeOffers   Knowledge[] @relation("KnowledgeOffers")
  knowledgeRequests Knowledge[] @relation("KnowledgeRequests")
}

view UserStats {
  profileId     Int   @unique
  averageRating Float
  reviewCount   Int
}
