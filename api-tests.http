### Variables
@baseUrl = http://localhost:3000/api
@email = test@example.com
@password = Password123!
@nickname = testuser

### 1. Register User
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "firstName": "John",
  "middleName": "Doe",
  "lastName": "Smith",
  "nickname": "{{nickname}}"
}

> {% client.global.set("auth_token", response.body.accessToken); %}

### 2. Login User
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

> {% client.global.set("auth_token", response.body.accessToken); %}

### 3. Get My Profile (Flattened)
GET {{baseUrl}}/users/me
Authorization: Bearer {{auth_token}}

### 4. Update My Profile
PATCH {{baseUrl}}/users/me
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "bio": "New bio from test",
  "categories": ["Developer", "Designer"]
}

### 5. Get Public Profile by ID
# Change 1 to a real user ID from registration response
GET {{baseUrl}}/users/1

### 6. Delete My Account
DELETE {{baseUrl}}/users/me
Authorization: Bearer {{auth_token}}
